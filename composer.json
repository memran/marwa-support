{
  "name": "memran/marwa-support",
  "description": "Framework-agnostic PHP support library with typed helpers for strings, arrays, files, objects, validation, and security primitives",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Mohammad Emran",
      "email": "memran.dhk@gmail.com"
    }
  ],
  "keywords": [
    "php",
    "helpers",
    "utilities",
    "validation",
    "security"
  ],
  "require": {
    "php": "^8.2",
    "ext-json": "*",
    "ext-mbstring": "*",
    "ext-openssl": "*"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.66",
    "phpstan/phpstan": "^1.12",
    "phpunit/phpunit": "^9.6.33"
  },
  "autoload": {
    "psr-4": {
      "Marwa\\Support\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Marwa\\Support\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "test:coverage": "phpunit --coverage-text --colors=never",
    "analyse": "phpstan analyse --configuration=phpstan.neon.dist --no-progress --debug --memory-limit=512M",
    "lint": "php-cs-fixer fix --config=.php-cs-fixer.dist.php --dry-run --diff --verbose --sequential",
    "fix": "php-cs-fixer fix --config=.php-cs-fixer.dist.php --verbose --sequential",
    "ci": [
      "@lint",
      "@analyse",
      "@test"
    ]
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "platform": {
      "php": "8.2.0"
    },
    "sort-packages": true,
    "optimize-autoloader": true
  }
}
